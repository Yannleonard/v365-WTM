# =============================================================================
# Castor — environment template.
#
#   cp deploy/env.example .env
#   # then edit .env (at minimum, set a real CASTOR_SECRET_KEY)
#   docker compose -f deploy/docker-compose.yml --env-file .env up -d
#
# docker compose auto-loads a `.env` file sitting next to where you run it; the
# committed compose files reference these variables. NEVER commit your real .env.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — secret key for AES-256-GCM (TOTP secret sealing) and derived crypto.
# Must be a 32-byte key, encoded as 64 hexadecimal characters. The backend
# refuses to start if this is unset or not exactly 32 bytes.
#
#   Generate:   openssl rand -hex 32
#   (NOTE: `openssl rand -hex 16` -> 32 chars = only 16 bytes = WRONG. Use -hex 32.)
# -----------------------------------------------------------------------------
CASTOR_SECRET_KEY=REPLACE_ME_WITH_OUTPUT_OF_openssl_rand_-hex_32

# -----------------------------------------------------------------------------
# Docker socket group id — lets Castor (non-root, uid 65532) talk to the socket
# without running as root. Find it on the host:
#
#   getent group docker | cut -d: -f3      # commonly 999
#
# Defaults to 999 if unset.
# -----------------------------------------------------------------------------
DOCKER_GID=999

# -----------------------------------------------------------------------------
# OPTIONAL — listen address inside the container (host port is mapped in compose).
# -----------------------------------------------------------------------------
# CASTOR_HTTP_ADDR=:8080

# -----------------------------------------------------------------------------
# OPTIONAL — trust reverse-proxy forwarding headers (X-Forwarded-Proto / -For).
# Set to true ONLY when Castor sits behind a trusted TLS-terminating proxy; this
# governs the Secure cookie flag and the client IP recorded in the audit log.
# -----------------------------------------------------------------------------
# CASTOR_TRUST_PROXY=false

# -----------------------------------------------------------------------------
# OPTIONAL — self-protection seed (Castor's own container id/name). The backend
# also resolves its real container id at runtime from /proc/self/cgroup; this is
# a fallback hint. Compose passes the service container_name ("castor").
# -----------------------------------------------------------------------------
# CASTOR_SELF_CONTAINER_ID=castor

# -----------------------------------------------------------------------------
# OPTIONAL — one-time token gating POST /api/v1/bootstrap for unattended installs.
# Leave unset to use the interactive first-run "create admin" screen.
# -----------------------------------------------------------------------------
# CASTOR_BOOTSTRAP_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL — alternate Docker endpoint (e.g. a scoped docker-socket-proxy) instead
# of the bind-mounted raw socket. Hardened deployments should prefer a proxy.
#   e.g. tcp://docker-socket-proxy:2375
# -----------------------------------------------------------------------------
# CASTOR_DOCKER_HOST=

# -----------------------------------------------------------------------------
# OPTIONAL (Kubernetes overlay) — path to the mounted kubeconfig INSIDE the
# container. Set automatically by deploy/docker-compose.kube.yml.
# -----------------------------------------------------------------------------
# CASTOR_KUBECONFIG=/home/nonroot/.kube/config

# -----------------------------------------------------------------------------
# OPTIONAL — SQLite database path inside the container (on the /data volume).
# -----------------------------------------------------------------------------
# CASTOR_DB_PATH=/data/castor.db
